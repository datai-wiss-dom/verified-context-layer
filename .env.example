# Copy to .env and fill in real values. .env is git-ignored; this file is committed.
# Every key below is read by the code (src/*.py, vcl_audience_demo/*.py).

# GCP project the Data Product + BigQuery views live in
VCL_PROJECT=your-project-id
# GCP project NUMBER (used by src/vcl.py --project-number and embedded in resource names)
VCL_PROJECT_NUMBER=your-project-number
VCL_LOCATION=us-central1

# Full lookup_context resource name of the customer Data Product (search_entries dataplexEntry.name)
VCL_DP_RESOURCE=projects/your-project-number/locations/us-central1/entryGroups/@dataplex/entries/projects/your-project-number/locations/us-central1/dataProducts/your-data-product
# Full resource name of the verification aspect type
VCL_ASPECT_TYPE=projects/your-project-number/locations/us-central1/aspectTypes/verification

# VCL wrapper MCP endpoint (agent connects here, not to KC directly)
VCL_WRAPPER_URL=http://127.0.0.1:8080/mcp
# Port the wrapper listens on (optional; default 8080)
VCL_PORT=8080

# Bearer token for the wrapper -> KC. SET AT RUNTIME, do not commit a real token:
#   export VCL_TOKEN=$(gcloud auth print-access-token)
VCL_TOKEN=your-access-token

# Model for the advisory semantic triage (optional; default gemini-2.5-flash)
VCL_TRIAGE_MODEL=gemini-2.5-flash

# ---- setup/ bootstrap keys (used by setup/bootstrap/*.sh; harmless to the demo) ----
# Data Product owner email (written into the DP by 02_create_dp.sh)
VCL_OWNER_EMAIL=your-account@example.com
# Datasets. VCL_VIEWS_DATASET must stay ecommerce_views (the demo agent references it).
VCL_BASE_DATASET=ecommerce
VCL_VIEWS_DATASET=ecommerce_views
# Data Product + catalog identifiers (defaults are fine)
VCL_DP_ID=ecommerce-customer-intelligence
VCL_ENTRY_GROUP=@dataplex
VCL_QUALITY_SCAN_ID=customers-quality

# ---- steward-workflow keys (drift watcher / Cloud Shell deep link) ----
# Public git repo the "Open in Cloud Shell" deep link clones (holds steward/walkthrough_*.md)
VCL_GIT_REPO=https://github.com/your-org/your-repo
# Pub/Sub topic the drift watcher publishes alerts to
VCL_ALERT_TOPIC=vcl-governance-drift-alerts
