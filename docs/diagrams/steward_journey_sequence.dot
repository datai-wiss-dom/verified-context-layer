// Author: Wissem Khlifi · July 2026
// VCL — Steward Journey (Graphviz DOT; a top-down journey, not a literal UML sequence)
// Render: dot -Tsvg steward_journey_sequence.dot -o steward_journey_sequence.svg
//
// Verified against the code. Key structural facts:
//  * enforce writes ONLY the verdict (verification.source_tier) + emits the log. It does NOT
//    write the Governance Drift aspect and does NOT classify (INV-1). The display aspect +
//    cosmetic/substantive classification come from a SEPARATE advisory path: vcl_triage.py
//    (LLM) classifies; write_drift_aspect.py writes the display aspect.
//  * seal writes ONLY verified + provenance. RESOLVED is a SEPARATE chained step
//    (write_drift_aspect.py --resolve), not seal.
//  * ROUTING (restored fail-safe): the Monitoring alert deep link targets the SUBSTANTIVE
//    walkthrough — the file with NO re-certify command. EVERY alert lands there first. The
//    re-certify command is reached ONLY via an onward LINK (a link, not a command) after the
//    steward reads the classification. Structural, not a warning. (Dynamic routing used to
//    live in drift_watcher.py, superseded; this restores the default-safe behaviour.)
// Colour: blue = deterministic VERDICT (vcl.py); purple = advisory DISPLAY; green = gate;
//         gold = steward/action; red = withheld.
digraph steward_journey {
  rankdir=TB;
  graph [fontname="Helvetica", labelloc="t", fontsize=17,
         label="VCL — Steward Journey  (drift → alert → SEE → REVIEW → deliver)",
         pad=0.4, nodesep=0.5, ranksep=0.6, splines=spline];
  node  [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", margin="0.17,0.10"];
  edge  [fontname="Helvetica", fontsize=9, color="#444"];

  // --- deterministic verdict path (blue) ---
  src  [label="Source edited\la rule/schema changes, or a scan fails\l", fillcolor="#eceff3", color="#667788"];
  enf1 [label="vcl.py enforce  (deterministic, AI-free)\lre-read live state, compare vs sealed anchors\l", fillcolor="#dbe4ff", color="#3355aa"];
  enf2 [label="enforce writes the VERDICT ONLY:\lverification.source_tier = unverified\l", fillcolor="#dbe4ff", color="#3355aa"];
  enf3 [label="enforce emits VCL_DRIFT_DETECTED (WARNING)\lto logs/vcl-drift\l", fillcolor="#dbe4ff", color="#3355aa"];

  // --- separate advisory DISPLAY path (purple) — NOT enforce ---
  adv  [label=<<b>SEPARATE advisory step — the AI lives here, not in enforce</b><br align="left"/>vcl_triage.py (LLM) classifies cosmetic / substantive;<br align="left"/>write_drift_aspect.py writes Governance Drift = PENDING_REVIEW<br align="left"/>+ classification — DISPLAY ONLY, the gate never reads it<br align="left"/>>, fillcolor="#ece3fb", color="#6b46c1"];

  // --- agents blocked meanwhile (green) ---
  block [label=<<b>Meanwhile — agents are already blocked</b><br align="left"/>Agent → wrapper lookup_context → wrapper reads the verdict → unverified<br align="left"/>→ WITHHOLD + honest note ("do not infer or fabricate")<br align="left"/>the action tool ALSO refuses on the verdict — two structural layers<br align="left"/>>, fillcolor="#dcf3e2", color="#2f7d3a"];

  // --- alert + steward SEE ---
  alert [label="Logging → Monitoring policy 'VCL Drift Detected'\l→ Slack + email:  SEE url  +  REVIEW deep link\l→ walkthrough_substantive.md  (safe default: NO re-certify command)\l", fillcolor="#eef0f2", color="#556"];
  see   [label="Steward — 1. SEE: open the entry\lreads which dimension drifted + the AI cosmetic/substantive assessment\l", fillcolor="#fdf0d5", color="#b8860b"];

  // --- ACT lands on the substantive (no-seal) walkthrough by default ---
  actsub [label=<<b>2. REVIEW — the deep link opens the SUBSTANTIVE walkthrough</b><br align="left"/>EVERY alert lands here first. This file has NO re-certify command.<br align="left"/>The re-certify command is reachable ONLY via the onward link below,<br align="left"/>after the steward reads the classification — structural, not a warning.<br align="left"/>>, fillcolor="#fdf0d5", color="#b8860b"];

  decision [shape=diamond, label="AI assessment?\l(read on the entry)", fillcolor="#fff3cd", color="#b8860b", margin="0.05,0.02"];

  // cosmetic branch — reached only via the onward LINK
  onward [label="onward LINK (a link, not a command)\l→ opens steward/walkthrough_cosmetic.md\l", fillcolor="#fdf0d5", color="#b8860b", style="rounded,filled,dashed"];
  c2 [label="vcl.py seal  (steward AUTHORIZES, engine CERTIFIES)\lverification = verified + sealed_by + seal_event_id\l— VERDICT ONLY\l", fillcolor="#dbe4ff", color="#3355aa"];
  c3 [label="… && write_drift_aspect.py --resolve\lGovernance Drift = RESOLVED\l— DISPLAY ONLY, a SEPARATE chained step (not seal)\l", fillcolor="#ece3fb", color="#6b46c1"];

  // substantive branch
  s1 [label="substantive: investigate — which rule changed, confirm with the owner\lNO re-certify command exists on this path\l", fillcolor="#fdf0d5", color="#b8860b"];
  s2 [label="stays UNVERIFIED — context remains withheld\luntil the change is resolved (the safe default)\l", fillcolor="#f6d6d6", color="#c0272d"];

  deliver [label="Agent retry → wrapper reads verdict → verified\l→ DELIVER full governed context\l", fillcolor="#dcf3e2", color="#2f7d3a"];

  footer [shape=note, fontsize=9, fillcolor="#fffbe6", color="#b8860b",
    label="The human AUTHORIZES; the deterministic engine CERTIFIES — no status field is ever\lhand-flipped. The VERDICT (verification aspect) and the DISPLAY (governance-drift aspect)\lare written by DIFFERENT components. Every alert defaults to the no-seal file; the seal is\lreachable only after passing through the file that requires reading the classification.\l"];

  // --- spine ---
  src  -> enf1 [label="edit / scan fails"];
  enf1 -> enf2 [label="anchors diverge (e.g. semantic)"];
  enf2 -> enf3;
  enf3 -> alert;
  alert -> see [label="steward notified"];
  see  -> actsub;
  actsub -> decision;
  decision -> onward [label="cosmetic"];
  onward -> c2 [label="run the command"];
  c2 -> c3 [label="chained (&&)"];
  c3 -> deliver [label="verified → context flows again"];
  decision -> s1 [label="substantive / unknown"];
  s1 -> s2;

  // --- side paths (dashed) ---
  enf2 -> adv   [label="separate advisory\nwrite (display)", style=dashed, color="#6b46c1", fontcolor="#6b46c1"];
  enf2 -> block [label="verdict already\ngates agents", style=dashed, color="#2f7d3a", fontcolor="#2f7d3a"];
  s2 -> footer [style=invis];
  deliver -> footer [style=invis];
}
